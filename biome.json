{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab",
    "lineWidth": 120
  },
  "files": {
    "include": ["docs/.vitepress/**/*.ts", "docs/.vitepress/**/*.vue"],
    "ignore": ["node_modules", "dist", "docs/.vitepress/cache", "docs/.vitepress/dist", "*.md"]
  }
}
